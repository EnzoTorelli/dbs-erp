<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — DBS</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/sidebar.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="container-geral">

        <div class="sidebar">
            <div class="sidebar-brand">
                <h2>DBS</h2>
                <small>Sistema de Gestão</small>
            </div>

            <nav>
                <a href="/Dashboard" class="@(ViewData["Pagina"]?.ToString() == "Dashboard" ? "ativo" : "")">
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="1" y="1" width="6" height="6" rx="1" />
                        <rect x="9" y="1" width="6" height="6" rx="1" />
                        <rect x="1" y="9" width="6" height="6" rx="1" />
                        <rect x="9" y="9" width="6" height="6" rx="1" />
                    </svg>
                    Dashboard
                </a>
                <a href="/Clientes" class="@(ViewData["Pagina"]?.ToString() == "Clientes" ? "ativo" : "")">
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                        <circle cx="8" cy="5" r="3" />
                        <path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6" />
                    </svg>
                    Clientes
                </a>
                <a href="/Produtos" class="@(ViewData["Pagina"]?.ToString() == "Produtos" ? "ativo" : "")">
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M2 4h12v10H2z" />
                        <path d="M5 4V2h6v2" />
                    </svg>
                    Produtos
                </a>
                <a href="/Vendas" class="@(ViewData["Pagina"]?.ToString() == "Vendas" ? "ativo" : "")">
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M1 12 L5 7 L9 9 L15 3" />
                        <polyline points="11,3 15,3 15,7" />
                    </svg>
                    Vendas
                </a>
                <a href="/Ordens" class="@(ViewData["Pagina"]?.ToString() == "Ordens" ? "ativo" : "")">
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="1" y="3" width="14" height="11" rx="1" />
                        <path d="M5 3V1h6v2" />
                        <path d="M5 8h6M5 11h4" />
                    </svg>
                    Ordens
                </a>
            </nav>

            <div class="sidebar-footer">
                <div class="user-info">
                    <div class="user-avatar">JD</div>
                    <div>
                        <div class="user-nome">João Dev</div>
                        <div class="user-cargo">Admin</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="conteudo">
            @RenderBody()
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>